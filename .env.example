# Optional. If omitted, the app will try to read sorftime_mcp.url from ~/.codex/config.toml
SORFTIME_MCP_URL="https://mcp.sorftime.com?key=YOUR_KEY"

# Optional. Required only when enabling Aoxia 1688 deep sourcing.
AOXIA_ACCESS_KEY="YOUR_AOXIA_ACCESS_KEY"
AOXIA_SECRET_KEY="YOUR_AOXIA_SECRET_KEY"

# Optional local port for the integrated app server
PORT="3000"
